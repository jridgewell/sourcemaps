{
  "tasks": {
    "benchmark": {},
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["../../esbuild.mjs", "../../tsconfig.json", "../../mts-types.mjs", "src/**"],
      "outputs": ["dist/**", "types/**"]
    },
    "clean": { "cache": false },
    "dev": { "cache": false },
    "lint": {
      "inputs": ["../../prettier.config.js", "../../tsconfig.json", "src/**"],
      "outputs": ["src/**"]
    },
    "lint:format": {
      "inputs": [
        "../../prettier.config.js",
        "src/**",
        "test/**"
      ],
      "outputs": [
        "src/**",
        "test/**"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  },
  "globalDependencies": ["tsconfig.json"]
}
